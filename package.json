{
  "name": "tr-figma-mcpserver",
  "version": "1.0.0",
  "description": "Hosted MCP server for downloading Figma images using access tokens",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "postinstall": "npm run build"
  },
  "keywords": [
    "mcp",
    "figma",
    "model-context-protocol",
    "azure",
    "image-download"
  ],
  "author": "Thomson Reuters",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.18.0",
    "cors": "^2.8.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "@types/node": "^20.0.0",
    "@types/express": "^4.17.0",
    "@types/cors": "^2.8.0",
    "tsx": "^4.0.0"
  }
}
